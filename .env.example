# =============================================================================
# FinFam - Environment Variables Configuration Template
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Configurações Globais da Aplicação
# -----------------------------------------------------------------------------
# APP_URL: O domínio público/URL onde esta aplicação está hospedada.
# Utilizado para links autoreferenciais, redirecionamentos e validações CORS.
APP_URL="http://localhost:3000"

# NODE_ENV: Ambiente de execução ('development', 'production', 'test')
NODE_ENV="development"

# PORT: Porta onde o servidor Express estará escutando (Padrão Ingress: 3000)
PORT=3000

# TIMEZONE: Fuso horário padrão da aplicação para processamento de datas e vencimentos
TIMEZONE="America/Fortaleza"

# -----------------------------------------------------------------------------
# 2. Segurança e Sessões
# -----------------------------------------------------------------------------
# SESSION_SECRET: Chave secreta de alta entropia utilizada para criptografia e 
# assinatura dos Cookies de Sessão dos usuários. Deve ser alterada em produção.
SESSION_SECRET="altere_este_segredo_por_um_hash_aleatorio_e_seguro_em_producao"

# -----------------------------------------------------------------------------
# 3. Conexão com o Banco de Dados MySQL
# -----------------------------------------------------------------------------
# DB_HOST: Endereço do servidor de banco de dados MySQL (ex: localhost ou IP)
DB_HOST="127.0.0.1"

# DB_PORT: Porta de conexão com o MySQL (padrão: 3306)
DB_PORT=3306

# DB_USER: Usuário com permissões de leitura/escrita no banco
DB_USER="finfam_user"

# DB_PASSWORD: Senha de acesso ao banco do usuário correspondente
DB_PASSWORD="finfam_password_forte"

# DB_NAME: Nome do banco de dados/esquema que armazenará as tabelas do FinFam
DB_NAME="finfam_db"

